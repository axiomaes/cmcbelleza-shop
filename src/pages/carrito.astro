---
// src/pages/carrito.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tu Carrito - CMC Belleza">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 min-h-[60vh]">
        <h1 class="text-3xl md:text-4xl font-extrabold text-dark mb-10 relative inline-block">
            Tu Carrito de la Compra
            <span class="absolute -bottom-2 left-0 w-1/3 h-1.5 bg-primary rounded-full"></span>
        </h1>

        <div id="empty-cart-view" class="hidden text-center py-20 bg-white/60 backdrop-blur-sm rounded-3xl border border-white/60 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto text-gray-300 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <h2 class="text-2xl font-bold text-dark mb-4">Tu carrito está vacío</h2>
            <p class="text-dark-muted mb-8">Parece que aún no has añadido ningún producto.</p>
            <a href="/#catalogo" class="inline-block px-8 py-3 bg-primary text-white font-bold rounded-full hover:bg-primary-hover hover:scale-105 transition-all duration-300">
                Volver a la tienda
            </a>
        </div>

        <div id="full-cart-view" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 space-y-4" id="cart-items-container">
            </div>

            <div class="bg-white/80 backdrop-blur-md p-6 sm:p-8 rounded-3xl shadow-sm border border-white/60 h-fit sticky top-28">
                <h2 class="text-xl font-bold text-dark mb-6 border-b border-gray-100 pb-4">Resumen del Pedido</h2>

                <div class="flex justify-between items-center mb-4 text-dark-muted">
                    <span>Artículos (<span id="summary-count">0</span>)</span>
                    <span id="summary-subtotal">0.00 €</span>
                </div>

                <div class="flex justify-between items-center mb-6 text-dark-muted border-b border-gray-100 pb-6">
                    <span>Envío</span>
                    <span class="text-sm">Calculado en el siguiente paso</span>
                </div>

                <div class="flex justify-between items-center mb-8">
                    <span class="text-xl font-bold text-dark">Total</span>
                    <span id="summary-total" class="text-2xl font-extrabold text-secondary">0.00 €</span>
                </div>

                <button id="checkout-btn" class="w-full bg-dark text-white py-4 rounded-full font-bold text-lg hover:bg-primary hover:shadow-lg transition-all duration-300">
                    Proceder al pago seguro
                </button>
            </div>

        </div>
    </main>
</BaseLayout>

<script>
    import { cartStore, removeProductFromCart, updateItemQuantity } from '../store/cart.js';

    // Referencias al DOM
    const emptyView = document.getElementById('empty-cart-view');
    const fullView = document.getElementById('full-cart-view');
    const itemsContainer = document.getElementById('cart-items-container');
    const summaryCount = document.getElementById('summary-count');
    const summarySubtotal = document.getElementById('summary-subtotal');
    const summaryTotal = document.getElementById('summary-total');

    // Renderizar la lista
    const renderCart = (cart) => {
        if (cart.items.length === 0) {
            fullView?.classList.add('hidden');
            emptyView?.classList.remove('hidden');
            return;
        }

        emptyView?.classList.add('hidden');
        fullView?.classList.remove('hidden');

        // Actualizar Resumen
        if (summaryCount) summaryCount.textContent = cart.itemCount.toString();
        if (summarySubtotal) summarySubtotal.textContent = `${cart.totals.total} €`;
        if (summaryTotal) summaryTotal.textContent = `${cart.totals.total} €`;

        // Inyectar HTML de productos
        if (itemsContainer) {
            itemsContainer.innerHTML = cart.items.map(item => `
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm border border-gray-50 flex flex-col sm:flex-row items-center gap-6 relative">
          
          <div class="flex-1 flex flex-col items-center sm:items-start text-center sm:text-left">
            <a href="/producto/${item.id}" class="text-lg font-bold text-dark hover:text-primary transition-colors line-clamp-2">${item.name}</a>
            <p class="text-xl font-extrabold text-secondary mt-2">${item.price} €</p>
          </div>

          <div class="flex items-center gap-4 mt-4 sm:mt-0">
            <div class="flex items-center bg-gray-50 rounded-full border border-gray-200">
              <button class="qty-btn minus w-8 h-8 flex items-center justify-center text-dark font-bold hover:text-primary transition-colors" data-id="${item.id}">-</button>
              <span class="w-8 text-center font-medium text-dark">${item.quantity}</span>
              <button class="qty-btn plus w-8 h-8 flex items-center justify-center text-dark font-bold hover:text-primary transition-colors" data-id="${item.id}">+</button>
            </div>
            
            <button class="remove-btn text-dark-muted hover:text-red-500 p-2 transition-colors" data-id="${item.id}" aria-label="Eliminar producto">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </div>
      `).join('');
        }
    };

    // Suscribirse a los cambios
    cartStore.subscribe(renderCart);

    // Delegación de eventos para botones dinámicos
    if (itemsContainer) {
        itemsContainer.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;

            // Eliminar producto
            const removeBtn = target.closest('.remove-btn');
            if (removeBtn && removeBtn instanceof HTMLElement) {
                const id = Number(removeBtn.dataset.id);
                removeProductFromCart(id);
                return;
            }

            // Cambiar cantidad
            const qtyBtn = target.closest('.qty-btn');
            if (qtyBtn && qtyBtn instanceof HTMLElement) {
                const id = Number(qtyBtn.dataset.id);
                const item = cartStore.get().items.find(i => i.id === id);
                if (item) {
                    const newQty = qtyBtn.classList.contains('plus') ? item.quantity + 1 : item.quantity - 1;
                    updateItemQuantity(id, newQty);
                }
            }
        });
    }
</script>